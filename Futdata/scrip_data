#!/usr/bin/env bash
# =====================================================
# Script: football_stats.sh
# Fuente: football-data.org (registro gratuito)
# Uso:    ./football_stats.sh
# =====================================================

API_KEY=56c6e074a34843548f4b4f3dd0a35f95
BASE_URL="https://api.football-data.org/v4"

# Colores
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# ---- Función genérica de petición ----
fetch() {
  curl -s -H "X-Auth-Token: ${API_KEY}" "${BASE_URL}/$1"
}

# ---- Tabla de posiciones ----
standings() {
  local league="${1:-PL}"   # PL=Premier League, PD=La Liga, SA=Serie A
  echo -e "${CYAN}${BOLD}=== TABLA DE POSICIONES: $league ===${NC}"
  fetch "competitions/${league}/standings" | \
    python3 -c "
import json, sys
data = json.load(sys.stdin)
tabla = data['standings'][0]['table']
print(f\"{'Pos':<4} {'Equipo':<25} {'PJ':<4} {'G':<4} {'E':<4} {'P':<4} {'GF':<5} {'GC':<5} {'DG':<6} {'Pts'}\")
print('-' * 65)
for t in tabla:
    print(f\"{t['position']:<4} {t['team']['name']:<25} {t['playedGames']:<4} {t['won']:<4} {t['draw']:<4} {t['lost']:<4} {t['goalsFor']:<5} {t['goalsAgainst']:<5} {t['goalDifference']:<6} {t['points']}\")
"
}

# ---- Próximos partidos ----
fixtures() {
  local league="${1:-PL}"
  echo -e "${CYAN}${BOLD}=== PRÓXIMOS PARTIDOS: $league ===${NC}"
  fetch "competitions/${league}/matches?status=SCHEDULED" | \
    python3 -c "
import json, sys
data = json.load(sys.stdin)
matches = data.get('matches', [])[:10]
for m in matches:
    fecha = m['utcDate'][:10]
    local = m['homeTeam']['name']
    visit = m['awayTeam']['name']
    jorn  = m.get('matchday', '?')
    print(f\"  Jornada {jorn} | {fecha} | {local:30} vs {visit}\")
"
}

# ---- Resultados recientes ----
results() {
  local league="${1:-PL}"
  echo -e "${CYAN}${BOLD}=== RESULTADOS RECIENTES: $league ===${NC}"
  fetch "competitions/${league}/matches?status=FINISHED" | \
    python3 -c "
import json, sys
data = json.load(sys.stdin)
matches = data.get('matches', [])
# Últimos 10
for m in matches[-10:]:
    fecha = m['utcDate'][:10]
    local = m['homeTeam']['name']
    visit = m['awayTeam']['name']
    gl    = m['score']['fullTime']['home']
    gv    = m['score']['fullTime']['away']
    print(f\"  {fecha} | {local:28} {gl} - {gv}  {visit}\")
"
}

# ---- Goleadores ----
scorers() {
  local league="${1:-PL}"
  echo -e "${CYAN}${BOLD}=== TOP GOLEADORES: $league ===${NC}"
  fetch "competitions/${league}/scorers?limit=15" | \
    python3 -c "
import json, sys
data = json.load(sys.stdin)
scorers = data.get('scorers', [])
print(f\"{'#':<4} {'Jugador':<28} {'Equipo':<25} {'Goles':<7} {'Asist.'}\")
print('-' * 75)
for i, s in enumerate(scorers, 1):
    p = s['player']['name']
    t = s['team']['name']
    g = s.get('goals', 0)
    a = s.get('assists', 0) or 0
    print(f\"{i:<4} {p:<28} {t:<25} {g:<7} {a}\")
"
}

# ---- Menú principal ----
menu() {
  echo -e "\n${BOLD}${GREEN}⚽  FOOTBALL STATS CLI  ⚽${NC}"
  echo -e "${YELLOW}Ligas disponibles:${NC} PL (Premier) | PD (La Liga) | SA (Serie A)"
  echo -e "                   BL1 (Bundesliga) | FL1 (Ligue 1) | CL (Champions)\n"
  echo "1) Tabla de posiciones"
  echo "2) Próximos partidos"
  echo "3) Resultados recientes"
  echo "4) Top goleadores"
  echo "5) Salir"
  echo -ne "\n${BOLD}Elige opción [1-5]:${NC} "
  read -r opt

  echo -ne "${BOLD}Liga [default: PL]:${NC} "
  read -r liga
  liga="${liga:-PL}"

  case "$opt" in
    1) standings "$liga" ;;
    2) fixtures  "$liga" ;;
    3) results   "$liga" ;;
    4) scorers   "$liga" ;;
    5) exit 0 ;;
    *) echo -e "${RED}Opción inválida${NC}" ;;
  esac
}

# Verifica dependencias
command -v curl   >/dev/null || { echo "Instala curl";   exit 1; }
command -v python3 >/dev/null || { echo "Instala python3"; exit 1; }

while true; do
  menu
  echo ""
done
